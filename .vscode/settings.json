{
    "auto-run-command.rules": [
        {
            "condition": "always",
            "command": [
                "workbench.action.debug.start", // Activates debugger in PowerShell Extension Terminal and switch to it
                "workbench.action.terminal.focusPrevious", // Switch to the useless pwsh terminal (creates a new terminal if there are none)
                "workbench.action.terminal.kill",
            ],
        }
    ],
    "editor.formatOnSave": true,
    "files.trimTrailingWhitespace": true,
    "powershell.codeFormatting.preset": "OTBS", // Without it, wrong formatting is still detected but not automatically fixed
    "powershell.cwd": ".",
    "powershell.scriptAnalysis.enable": true,
    "powershell.scriptAnalysis.settingsPath": "PSScriptAnalyzerSettings.psd1",
}